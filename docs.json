{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Velum",
  "description": "The invisible privacy layer for on-chain assets. What HTTPS did for the web, Velum does for money on-chain.",
  "colors": {
    "primary": "#6d5efc",
    "light": "#a5b4fc",
    "dark": "#4f46e5"
  },
  "favicon": "/logo/favicon.svg",
  "logo": {
    "light": "/logo/velum-light.svg",
    "dark": "/logo/velum-dark.svg",
    "href": "https://velum.finance"
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "heading": { "family": "Inter" },
    "body": { "family": "Inter" }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "introduction/what-is-velum",
              "introduction/how-it-works",
              "introduction/privacy-model"
            ]
          },
          {
            "group": "Using Velum",
            "pages": [
              "using-velum/add-funds",
              "using-velum/request-a-payment",
              "using-velum/cash-out",
              "using-velum/multichain"
            ]
          },
          {
            "group": "Protocol",
            "pages": [
              "protocol/architecture",
              "protocol/circuits",
              "protocol/relayer",
              "protocol/compliance",
              "protocol/contracts"
            ]
          },
          {
            "group": "Security",
            "pages": [
              "security/audits",
              "security/threat-model"
            ]
          }
        ]
      },
      {
        "tab": "Build",
        "groups": [
          {
            "group": "Build on Velum",
            "pages": [
              "build/sdk-quickstart",
              "build/integrate"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/yagamiinu/velum-docs"
      },
      {
        "label": "Website",
        "href": "https://velum.finance"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://app.velum.finance"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/VelumFinance",
      "github": "https://github.com/yagamiinu/velum-docs",
      "website": "https://velum.finance"
    }
  }
}
