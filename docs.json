      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://app.velum.finance"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/velum",
      "github": "https://github.com/velum"
    }
  }
}
